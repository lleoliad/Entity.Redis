<Project Sdk="Microsoft.NET.Sdk">
    
    <PropertyGroup>
        <PackageId>Entity.Redis</PackageId>
        <PackageVersion>0.1.0</PackageVersion>
        <Title>Entity.Redis</Title>
        <Authors>Lleoliad</Authors>
        <owners>Lleoliad</owners>
        <PackageOutputPath>../../nupkg</PackageOutputPath>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <Description>Redis support for the Entity/Fantasy server stack.</Description>
        <Copyright>Copyright 2026 Lleoliad</Copyright>
        <PackageLicenseFile>LICENSE</PackageLicenseFile>
        <PackageIcon>icon.png</PackageIcon>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageProjectUrl>https://github.com/lleoliad/Entity.Redis</PackageProjectUrl>
        <RepositoryUrl>https://github.com/lleoliad/Entity.Redis</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageTags>Entity, Redis, Cache</PackageTags>
        <AssemblyName>Entity.Redis</AssemblyName>
        <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
        <RootNamespace>Entities.Redis</RootNamespace>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>default</LangVersion>
        <IsPackable>true</IsPackable>
        <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
        <SignAssembly>true</SignAssembly>
<!--        <IncludeSymbols>true</IncludeSymbols>-->
<!--        <SymbolPackageFormat>snupkg</SymbolPackageFormat>-->
    </PropertyGroup>
    
    <ItemGroup>
        <ProjectReference Include="..\..\Entity\Entity.csproj"/>
        <PackageReference Include="FreeRedis" Version="1.5.5"/>
    </ItemGroup>
    
    <ItemGroup>
        <!-- 包元数据文件 -->
        <None Include="LICENSE" Pack="true" PackagePath="\" />
        <None Include="README.md" Pack="true" PackagePath="\" />
        <None Include="Assets/icon.png" Pack="true" PackagePath="\" Link="icon.png" />
    </ItemGroup>
</Project>
